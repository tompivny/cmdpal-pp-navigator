{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CmdPal: Deploy extension (x64)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/Deploy-CommandPaletteExtension.ps1",
        "-Platform",
        "x64",
        "-Configuration",
        "Debug",
        "-InstallMissingSdk"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
